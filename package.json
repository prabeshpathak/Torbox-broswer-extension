{
  "name": "torboxextension",
  "version": "alpha.0",
  "description": "Simple extension for using torbox",
  "main": "index.js",
   "scripts": {
    "dev:chrome": "NODE_ENV=development BROWSER=chrome vite build --watch",
    "dev:firefox": "NODE_ENV=development BROWSER=firefox vite build --watch",
    "build:chrome": "BROWSER=chrome vite build && node scripts/build.js chrome",
    "build:firefox": "BROWSER=firefox vite build && node scripts/build.js firefox",
    "build:all": "npm run build:chrome && npm run build:firefox",
    "start:firefox": "web-ext run -s dist/firefox --browser-console",
    "package:firefox": "web-ext build -s dist/firefox -a releases",
    "package:chrome": "cd dist/chrome && zip -r ../../releases/chrome-extension.zip ."
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0",
    "web-ext": "^7.11.0",
    "fs-extra": "^11.2.0"
  },
  "author": "",
  "license": "ISC"
}
